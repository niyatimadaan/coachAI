# Backend Environment Configuration

# Database Configuration (AWS RDS PostgreSQL)
DB_HOST=hostname
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_SSL=true

# Server Configuration
PORT=3000
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3001

# Session Configuration
SESSION_SECRET=your-secret-key-change-in-production
SESSION_EXPIRY_HOURS=24

# Video Storage Configuration
# Options: 'local' (development) or 's3' (production recommended)
VIDEO_STORAGE_PROVIDER=s3
VIDEO_TEMP_DIR=./uploads/temp
VIDEO_MAX_SIZE_MB=100
VIDEO_ALLOWED_FORMATS=mp4,mov,avi,webm

# AWS S3 Configuration (REQUIRED when VIDEO_STORAGE_PROVIDER=s3)
# Step 1: Create an S3 bucket in AWS Console
# Step 2: Create IAM user with S3 full access permissions
# Step 3: Generate access keys for the IAM user
# Step 4: Set the environment variables below with your AWS credentials
AWS_REGION=eu-north-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_S3_BUCKET=coachai-videos
AWS_S3_VIDEO_PREFIX=videos/

# S3 Signed URL Configuration
AWS_S3_SIGNED_URL_EXPIRY_MINUTES=60

# ML Analysis Configuration
DEFAULT_ML_TIER=lightweight_ml
ML_MODEL_DIR=./models
ML_PROCESSING_TIMEOUT=60000
ML_MAX_VIDEO_DURATION_SEC=120
ML_USE_GPU=false

# Video Processing Configuration
FFMPEG_PATH=/usr/bin/ffmpeg
VIDEO_FRAME_EXTRACTION_FPS=10
VIDEO_TARGET_RESOLUTION=720p
VIDEO_PROCESSING_QUEUE_ENABLED=false
VIDEO_PROCESSING_WORKERS=2

# AWS SageMaker Configuration (for pose detection)
# Step 1: Deploy MediaPipe pose detection model to SageMaker
# Step 2: Create an endpoint and note the endpoint name
# Step 3: Ensure IAM user has SageMaker InvokeEndpoint permissions
# Step 4: Set SAGEMAKER_ENDPOINT_NAME to your endpoint name
SAGEMAKER_ENDPOINT_NAME=basketball-pose-endpoint
USE_SAGEMAKER_POSE_DETECTION=true

# Azure OpenAI Configuration (for AI drill suggestions)
# Step 1: Create an Azure OpenAI resource in Azure Portal
# Step 2: Deploy GPT-4o model
# Step 3: Get the endpoint URL and API key from Azure Portal
# Step 4: Set the environment variables below
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/openai/deployments/gpt-4o/chat/completions?api-version=2025-01-01-preview
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
